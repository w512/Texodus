{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Texodus",
  "version": "../package.json",
  "identifier": "us.blokhin.texodus",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Texodus",
        "width": 1280,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: https: asset: http://asset.localhost; connect-src ipc: http://ipc.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [],
          "deny": [
            "$HOME/.ssh",
            "$HOME/.ssh/**",
            "$HOME/.aws",
            "$HOME/.aws/**",
            "$HOME/.gnupg",
            "$HOME/.gnupg/**",
            "$HOME/Library/Keychains",
            "$HOME/Library/Keychains/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app", "deb", "appimage", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown Document",
        "description": "Markdown text document",
        "role": "Editor",
        "mimeType": "text/markdown"
      },
      {
        "ext": ["txt"],
        "name": "Plain Text Document",
        "description": "Plain text document",
        "role": "Editor",
        "mimeType": "text/plain"
      }
    ]
  }
}
