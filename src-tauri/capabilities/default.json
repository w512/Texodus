{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "window_*"],
  "permissions": [
    "core:default",
    "core:menu:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-set-title",
    "opener:default",
    {
      "identifier": "opener:allow-reveal-item-in-dir",
      "allow": [{ "path": "**" }]
    },
    "fs:default",
    "fs:allow-stat",
    "fs:allow-read-dir",
    "fs:allow-watch",
    "fs:allow-unwatch",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-read-text-file",
    "fs:allow-read-file",
    "fs:allow-write-text-file",
    "fs:allow-write-file",
    "fs:allow-copy-file",
    {
      "identifier": "fs:scope",
      "deny": [
        { "path": "$HOME/.ssh" },
        { "path": "$HOME/.ssh/**" },
        { "path": "$HOME/.aws" },
        { "path": "$HOME/.aws/**" },
        { "path": "$HOME/.gnupg" },
        { "path": "$HOME/.gnupg/**" },
        { "path": "$HOME/Library/Keychains" },
        { "path": "$HOME/Library/Keychains/**" }
      ]
    },
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-confirm",
    "dialog:allow-message",
    "shell:default",
    "shell:allow-open",
    "core:window:allow-start-dragging",
    "window-state:default"
  ]
}
